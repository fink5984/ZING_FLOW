# Server
PORT=3000
# Public URL of this server (used for image proxy) - set in Railway
# Example: https://zing-flow-production.up.railway.app
BASE_URL=https://your-railway-app.up.railway.app

# ─── WhatsApp Business API ───────────────────────────────────────────
# Access token from Meta Business Suite (System User token)
WHATSAPP_TOKEN=your_whatsapp_access_token_here
# Phone Number ID from Meta Business Suite > WhatsApp > API Setup
PHONE_NUMBER_ID=your_phone_number_id_here
# Flow ID from Meta Business Suite > WhatsApp > Flows
FLOW_ID=your_flow_id_here

# ─── WhatsApp Flow Encryption ────────────────────────────────────────
# RSA Private Key in PEM format (replace actual newlines with \n)
# Generate with: openssl genrsa -out private_key.pem 2048
# Upload the matching PUBLIC key to Meta Flow Builder
FLOW_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# ─── Zing / JewishMusic API ──────────────────────────────────────────
# Firebase API key (found in the app's network requests)
FIREBASE_API_KEY=AIzaSyByyRIbRvi6MLOjfWqdv73B88x2QsVkOZA
# Firebase refresh token (from the app's auth session)
ZING_REFRESH_TOKEN=your_firebase_refresh_token_here
# App version header
ZING_APP_VERSION=3.6.5
