{
  "version": "6.3",
  "data_api_version": "3.0",
  "routing_model": {
    "SEARCH":        ["ARTIST_LIST"],
    "ARTIST_LIST":   ["ARTIST_ALBUMS"],
    "ARTIST_ALBUMS": ["ALBUM_TRACKS"],
    "ALBUM_TRACKS":  ["SUCCESS"]
  },
  "screens": [

    {
      "id": "SEARCH",
      "title": "Zing Music 🎵",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "חיפוש אמן"
          },
          {
            "type": "TextBody",
            "text": "הזן שם האמן שאתה מחפש (בעברית או באנגלית)"
          },
          {
            "type": "Form",
            "name": "search_form",
            "children": [
              {
                "type": "TextInput",
                "name": "artist_search",
                "label": "שם האמן",
                "input-type": "text",
                "required": false,
                "helper-text": "ניתן להשאיר ריק לצפייה בכל האמנים"
              },
              {
                "type": "Footer",
                "label": "חפש",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "artist_search": "${form.artist_search}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "ARTIST_LIST",
      "title": "בחר אמן",
      "data": {
        "artists": {
          "type": "array",
          "__example__": [
            {
              "id": "1",
              "title": "מרדכי בן דוד",
              "description": "Mordechai Ben David",
              "image": "https://jewishmusic.fm/wp-content/uploads/2025/02/%D7%90%D7%94%D7%A8%D7%9F-%D7%A8%D7%96%D7%90%D7%9C.jpg"
            },
            {
              "id": "2",
              "title": "אברהם פריד",
              "description": "Avraham Fried",
              "image": "https://jewishmusic.fm/wp-content/uploads/2025/02/%D7%90%D7%94%D7%A8%D7%9F-%D7%A8%D7%96%D7%90%D7%9C.jpg"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id":          { "type": "string" },
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "image":       { "type": "string" }
            }
          }
        },
        "subtitle": {
          "type": "string",
          "__example__": "נמצאו 120 אמנים"
        },
        "page_chips": {
          "type": "array",
          "__example__": [
            { "id": "0", "title": "1" },
            { "id": "1", "title": "2" },
            { "id": "2", "title": "3" }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id":    { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "show_pager": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextBody",
            "text": "${data.subtitle}"
          },
          {
            "type": "Form",
            "name": "artist_form",
            "children": [
              {
                "type": "ChipsSelector",
                "name": "selected_page",
                "label": "עמוד",
                "min-selected-items": 0,
                "max-selected-items": 1,
                "data-source": "${data.page_chips}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "selected_artist",
                "label": "אמנים",
                "required": false,
                "data-source": "${data.artists}"
              },
              {
                "type": "Footer",
                "label": "בחר",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "selected_artist": "${form.selected_artist}",
                    "selected_page":   "${form.selected_page}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "ARTIST_ALBUMS",
      "title": "אלבומים",
      "data": {
        "artist_name": {
          "type": "string",
          "__example__": "מרדכי בן דוד"
        },
        "albums": {
          "type": "array",
          "__example__": [
            {
              "id": "101",
              "title": "אלבום לדוגמה",
              "description": "2023",
              "image": "https://jewishmusic.fm/wp-content/uploads/2022/07/%D7%A7%D7%95%D7%91%D7%99-%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%95%D7%99%D7%9D-%D7%96%D7%9B%D7%95%D7%AA-150x150.jpg"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id":          { "type": "string" },
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "image":       { "type": "string" }
            }
          }
        },
        "page_chips": {
          "type": "array",
          "__example__": [
            { "id": "0", "title": "1" },
            { "id": "1", "title": "2" }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id":    { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "show_pager": {
          "type": "boolean",
          "__example__": true
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.artist_name}"
          },
          {
            "type": "Form",
            "name": "album_form",
            "children": [
              {
                "type": "ChipsSelector",
                "name": "selected_page",
                "label": "עמוד",
                "min-selected-items": 0,
                "max-selected-items": 1,
                "data-source": "${data.page_chips}"
              },
              {
                "type": "RadioButtonsGroup",
                "name": "selected_album",
                "label": "בחר אלבום",
                "required": false,
                "data-source": "${data.albums}"
              },
              {
                "type": "Footer",
                "label": "בחר",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "selected_album": "${form.selected_album}",
                    "selected_page":  "${form.selected_page}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "ALBUM_TRACKS",
      "title": "שירים",
      "data": {
        "album_name": {
          "type": "string",
          "__example__": "אלבום לדוגמה"
        },
        "album_id": {
          "type": "string",
          "__example__": "101"
        },
        "tracks": {
          "type": "array",
          "__example__": [
            {
              "id": "__download_all__",
              "title": "⬇️ הורד את כל האלבום",
              "description": "10 שירים",
              "image": "https://jewishmusic.fm/wp-content/uploads/2022/07/%D7%A7%D7%95%D7%91%D7%99-%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%95%D7%99%D7%9D-%D7%96%D7%9B%D7%95%D7%AA-150x150.jpg"
            },
            {
              "id": "5001",
              "title": "אור חדש",
              "description": "3:45",
              "image": "https://jewishmusic.fm/wp-content/uploads/2022/07/%D7%A7%D7%95%D7%91%D7%99-%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%95%D7%99%D7%9D-%D7%96%D7%9B%D7%95%D7%AA-150x150.jpg"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "id":          { "type": "string" },
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "image":       { "type": "string" }
            }
          }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "${data.album_name}"
          },
          {
            "type": "TextCaption",
            "text": "בחר שיר להאזנה, או בחר 'הורד את כל האלבום'"
          },
          {
            "type": "Form",
            "name": "tracks_form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "selected_track",
                "label": "שירים",
                "required": true,
                "data-source": "${data.tracks}"
              },
              {
                "type": "Footer",
                "label": "שלח",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "selected_track": "${form.selected_track}",
                    "album_id":       "${data.album_id}"
                  }
                }
              }
            ]
          }
        ]
      }
    },

    {
      "id": "SUCCESS",
      "title": "נשלח! ✅",
      "terminal": true,
      "data": {
        "message": {
          "type": "string",
          "__example__": "🎵 השיר ישלח אליך עוד רגע..."
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "תודה!"
          },
          {
            "type": "TextBody",
            "text": "${data.message}"
          }
        ]
      }
    }

  ]
}
